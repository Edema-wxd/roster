// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------------
// User account — one per person who signs up. Each account owns its own
// private roster of tracked partners (Person.ownerId / Visit.ownerId below)
// — this is NOT the same as Person.userId (reserved for a tracked partner's
// own future self-login, a separate unbuilt feature, see Project.md §6).
// Login is identifier (any string — email or username) + a numeric PIN,
// hashed with scrypt (see src/lib/auth.ts). `pinHash` is nullable only to
// let the pre-multi-user admin row migrate by setting a PIN on next login
// (see the ownerId-backfill migration) — every account created going
// forward always has one.
// ------------------------------------------------------------
enum Role {
  USER
  SUPER_ADMIN
}

model User {
  id          String    @id @default(cuid())
  identifier  String    @unique
  pinHash     String?
  createdAt   DateTime  @default(now())
  // Set when the account finishes (or skips) first-run onboarding. Null =
  // hasn't onboarded yet → the /onboarding flow shows. The migration
  // backfills existing accounts to now() so only fresh sign-ups see it.
  onboardedAt DateTime?
  // Gates read/respond access to the /feedback board (see feedback/actions.ts).
  // Every account defaults to USER; SUPER_ADMIN is granted manually.
  role        Role      @default(USER)

  people Person[] @relation("PersonOwner")
  visits Visit[]  @relation("VisitOwner")
}

// ------------------------------------------------------------
// Person — a tracked partner
// ------------------------------------------------------------
enum Gender {
  WOMAN
  MAN
  OTHER
}

model Person {
  id              String  @id @default(cuid())
  name            String
  color           String
  notes           String?
  allergies       String?
  foodPreferences String?
  isActive        Boolean @default(true)

  gender               Gender  @default(WOMAN)
  // Defaulted from gender at creation time (WOMAN/OTHER -> true, MAN -> false),
  // but always overridable per person — gender itself never hard-gates the UI,
  // this flag does. All cycle-tracking screens/queries must check this flag.
  cycleTrackingEnabled Boolean @default(true)

  // Prediction baseline — always user-editable, used until enough
  // history exists to weight an adaptive average.
  defaultCycleLength       Int @default(28)
  defaultPeriodLength      Int @default(5)
  // Luteal phase length is far less variable than follicular phase and is
  // the standard anchor for back-calculating a predicted ovulation date
  // from the next predicted period start.
  defaultLutealPhaseLength Int @default(14)

  // Denormalized prediction cache, recomputed whenever a cycle is
  // added/edited/deleted. Avoids recalculating mean/stdev on every
  // dashboard/calendar load. Source of truth is still Cycle history.
  predictedCycleLength     Float?
  predictedVariabilityDays Float?
  predictionLastCalculated DateTime?

  // Nullable link for future self-login support (see Project.md §6) — a
  // DIFFERENT concept from ownerId below: this would be the tracked
  // partner's own account, not the account managing this record.
  userId String?

  // The account that created/manages this Person — every query and
  // mutation must scope by this so one account's roster is invisible to
  // another's (see Project.md §6, Design.md §7).
  ownerId String
  owner   User   @relation("PersonOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cycles   Cycle[]
  visits   VisitPerson[]
  intimacy IntimacyEntry[]

  @@index([isActive])
  @@index([ownerId])
}

// ------------------------------------------------------------
// Cycle — one logged period per person. Per-day detail lives in
// CycleDayLog.
// ------------------------------------------------------------
model Cycle {
  id        String    @id @default(cuid())
  personId  String
  startDate DateTime
  endDate   DateTime?

  // Actual cycle length / period duration for this logged cycle,
  // editable independent of the person's rolling default/prediction.
  cycleLength  Int?
  periodLength Int?

  birthControlNotes String?
  notes             String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  person  Person        @relation(fields: [personId], references: [id], onDelete: Cascade)
  dayLogs CycleDayLog[]

  @@index([personId, startDate])
}

enum FlowIntensity {
  LIGHT
  MEDIUM
  HEAVY
}

enum OvulationTestResult {
  NEGATIVE
  POSITIVE
  PEAK
}

enum Symptom {
  CRAMPS
  HEADACHE
  MOOD_SWINGS
  FATIGUE
  BLOATING
  BREAST_TENDERNESS
  ACNE
  BACK_PAIN
  NAUSEA
  FOOD_CRAVINGS
  INSOMNIA
}

model CycleDayLog {
  id      String @id @default(cuid())
  cycleId String
  cycle   Cycle  @relation(fields: [cycleId], references: [id], onDelete: Cascade)

  date                DateTime
  flowIntensity       FlowIntensity?
  symptoms            Symptom[]
  basalBodyTemp       Float?
  ovulationTestResult OvulationTestResult?
  notes               String?

  @@unique([cycleId, date])
}

// ------------------------------------------------------------
// Intimacy log — per person, per day (added mid-build, not in
// the original spec).
// ------------------------------------------------------------
model IntimacyEntry {
  id        String   @id @default(cuid())
  personId  String
  date      DateTime
  protected Boolean
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([personId, date])
}

// ------------------------------------------------------------
// Visit / Appointment
// ------------------------------------------------------------
enum VisitType {
  CASUAL
  FORMAL
}

enum VisitStatus {
  PLANNED
  CONFIRMED
  DONE
  CANCELLED
}

model Visit {
  id          String      @id @default(cuid())
  scheduledAt DateTime
  type        VisitType   @default(CASUAL)
  status      VisitStatus @default(PLANNED)
  notes       String?

  // Scoped directly (rather than derived through VisitPerson -> Person)
  // since a visit's people are all expected to belong to the same account
  // and this keeps every dashboard query a flat where-clause.
  ownerId String
  owner   User   @relation("VisitOwner", fields: [ownerId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  people VisitPerson[]

  @@index([scheduledAt])
  @@index([ownerId])
}

// Join table — a visit can involve one or more tracked people.
// Deliberately scoped to Person only: a visit with someone not being
// cycle-tracked just means creating that Person with tracking off.
model VisitPerson {
  id       String @id @default(cuid())
  visitId  String
  personId String

  visit  Visit  @relation(fields: [visitId], references: [id], onDelete: Cascade)
  person Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([visitId, personId])
}

// ------------------------------------------------------------
// App feedback — a personal backlog for feedback/bug reports about the
// app itself, not tied to any Person/Visit. Deliberately not scoped by
// ownerId: this is a feedback log about the product, not per-tenant data,
// so it stays a single shared list regardless of how multi-user ownership
// (see User/ownerId above) evolves.
// ------------------------------------------------------------
enum FeedbackStatus {
  OPEN
  IN_PROGRESS
  DONE
}

model Feedback {
  id        String         @id @default(cuid())
  message   String
  rating    Int? // optional 1-5 star rating
  status    FeedbackStatus @default(OPEN)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  comments FeedbackComment[]

  @@index([status])
}

model FeedbackComment {
  id         String   @id @default(cuid())
  feedbackId String
  body       String
  createdAt  DateTime @default(now())

  feedback Feedback @relation(fields: [feedbackId], references: [id], onDelete: Cascade)

  @@index([feedbackId])
}
